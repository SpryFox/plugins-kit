{
  "tools": [
    {
      "name": "git",
      "install": {
        "macos": "brew install git",
        "windows": "winget install --id Git.Git -e --source winget",
        "ubuntu": "sudo apt install -y git"
      }
    }
  ],
  "venv": {
    "check_imports": ["yaml"]
  },
  "config": {
    "file": "config.yaml",
    "defaults_source": "defaults/config.yaml",
    "required_fields": {
      "GREETING_NAME": {
        "default": "World",
        "user_msg": "Name to use in greeting",
        "agent_msg": "Set GREETING_NAME in {config_path}"
      },
      "FAVORITE_COLOR": {
        "default": "blue",
        "user_msg": "Your favorite color",
        "agent_msg": "Set FAVORITE_COLOR in {config_path}"
      }
    }
  },
  "git_deps": [
    {
      "url": "https://github.com/octocat/Hello-World",
      "branch": "master",
      "sparse_paths": ["README"]
    }
  ]
}
