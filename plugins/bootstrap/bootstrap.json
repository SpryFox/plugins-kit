{
  "tools": [
    {
      "name": "jq",
      "install": {
        "windows": "winget install --id jqlang.jq --accept-source-agreements --accept-package-agreements --silent --disable-interactivity",
        "macos": "brew install jq",
        "ubuntu": "manual"
      }
    }
  ],
  "marketplaces": [
    {
      "name": "plugins-kit",
      "source": "https://github.com/kitaekatt/plugins-kit.git",
      "alwaysUpdate": true
    }
  ],
  "plugins": [
    {"ref": "plugins-kit:bootstrap", "enabled": true}
  ]
}
