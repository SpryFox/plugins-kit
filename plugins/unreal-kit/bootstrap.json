{
  "tools": [
    {
      "name": "p4",
      "install": {
        "macos": "brew install --cask perforce",
        "windows": "manual",
        "ubuntu": "manual"
      }
    }
  ],
  "venv": {
    "check_imports": ["upyrc", "yaml", "websocket"]
  },
  "shared_lib_imports": ["bootstrap_lib"],
  "project_config": {
    "file": ".local-data/plugins-kit/unreal-kit/config.yaml",
    "legacy_file": ".local-data/unreal-kit/config.yaml",
    "required_fields": ["uproject", "engine_dir"],
    "autodetect": "custom_bootstrap.py autodetect"
  },
  "config": {
    "file": "config.yaml",
    "defaults_source": "defaults/config.yaml",
    "required_fields": {
      "uproject": {
        "user_msg": "Path to .uproject file",
        "agent_msg": "Ask the user for their .uproject file path. Write it to {config_path} AND to <project_root>/.local-data/plugins-kit/unreal-kit/config.yaml (the per-project config)."
      },
      "engine_dir": {
        "user_msg": "Path to UE engine directory",
        "agent_msg": "Ask the user for their UE engine directory. Write it to {config_path} AND to <project_root>/.local-data/plugins-kit/unreal-kit/config.yaml (the per-project config)."
      }
    }
  },
  "ini_settings": [
    {
      "file": "${uproject_dir}/Config/UserEngine.ini",
      "section": "[/Script/PythonScriptPlugin.PythonScriptPluginSettings]",
      "settings": {
        "bRemoteExecution": "True",
        "bIsDeveloperMode": "True"
      }
    }
  ],
  "git_deps": [
    {
      "url": "https://github.com/hannesdelbeke/unreal-pip.git",
      "branch": "main",
      "commit": "c3b924797ada53b22c17e18101d0d29713766e0a"
    }
  ],
  "sync_to_data": [
    {"src": "lib", "dst": "lib"}
  ],
  "pypi_packages": [
    {
      "package": "unreal-stub",
      "extract_to": "${plugin_root}/skills/ue-python-api/stubs/unreal.py"
    }
  ],
  "plugins": [
    {"ref": "plugins-kit:unreal-kit", "enabled": true, "scope": "user"}
  ],
  "script": {
    "path": "custom_bootstrap.py",
    "entry_point": "bootstrap"
  }
}
