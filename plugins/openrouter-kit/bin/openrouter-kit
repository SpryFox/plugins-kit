#!/usr/bin/env bash
# openrouter-kit -- shim that invokes the bundled CLI via the standalone
# Python that bootstrap installs. The CLI is stdlib-only and adds its own
# lib/ to sys.path, so no venv is needed.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CLI="$PLUGIN_ROOT/scripts/openrouter_kit_cli.py"

OS="$(uname -s 2>/dev/null || echo Unknown)"
if [[ "$OS" == MINGW* ]] || [[ "$OS" == MSYS* ]] || [[ "$OS" == CYGWIN* ]]; then
    PY="${HOME}/.local/share/python-standalone/python/python.exe"
else
    PY="${HOME}/.local/share/python-standalone/python/bin/python3"
fi

if [ ! -x "$PY" ]; then
    # Fall back to anything on PATH; bootstrap normally guarantees the
    # standalone interpreter, but degrade gracefully if it is missing.
    if command -v python3 >/dev/null 2>&1; then
        PY="python3"
    elif command -v python >/dev/null 2>&1; then
        PY="python"
    else
        echo "openrouter-kit: no Python interpreter found" >&2
        exit 1
    fi
fi

exec "$PY" "$CLI" "$@"
