{
  "tools": [
    {
      "name": "git",
      "install": {
        "macos": "brew install git",
        "windows": "winget install --id Git.Git -e --source winget",
        "ubuntu": "sudo apt install -y git"
      }
    }
  ],
  "path_entries": ["~/.local/bin"],
  "project_venv": {
    "extras": ["dev"],
    "check_imports": ["pytest"]
  }
}
