{
  "tools": [
    {
      "name": "p4",
      "install": {
        "macos": "brew install --cask perforce",
        "windows": "manual",
        "ubuntu": "manual"
      }
    },
    {
      "name": "uv",
      "install": {
        "macos": "curl -LsSf https://astral.sh/uv/install.sh | sh",
        "windows": "powershell -ExecutionPolicy ByPass -c \"irm https://astral.sh/uv/install.ps1 | iex\"",
        "ubuntu": "curl -LsSf https://astral.sh/uv/install.sh | sh"
      }
    },
    {
      "name": "claude",
      "install": {
        "macos": "manual",
        "windows": "manual",
        "ubuntu": "manual"
      }
    }
  ],
  "venv": {
    "check_imports": []
  },
  "project_config": {
    "file": ".claude/p4-kit.yaml",
    "required_fields": ["P4PORT", "P4USER"],
    "autodetect": "custom_bootstrap.py autodetect"
  },
  "git_deps": [
    {
      "url": "https://github.com/kitaekatt/code-review-research",
      "branch": "main",
      "sparse_paths": ["agents/"]
    }
  ],
  "config": {
    "file": "config.yaml",
    "defaults_source": "defaults/config.yaml",
    "required_fields": {
      "P4PORT": {
        "user_msg": "Perforce server address (e.g. ssl:perforce:1666)",
        "agent_msg": "Ask the user for their Perforce server address. Write it to {config_path} AND to <project_root>/.claude/p4-kit.yaml (the per-project config)."
      },
      "P4USER": {
        "user_msg": "Perforce username",
        "agent_msg": "Ask the user for their Perforce username. Write it to {config_path} AND to <project_root>/.claude/p4-kit.yaml (the per-project config)."
      },
      "DEFAULT_AGENT": {
        "user_msg": "Default review agent",
        "agent_msg": "Ask the user which agent to use for reviews. Write to {config_path} as DEFAULT_AGENT",
        "default": "claude-opus"
      }
    }
  }
}
