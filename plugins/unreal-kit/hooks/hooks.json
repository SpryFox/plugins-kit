{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/userpromptsubmit/ue-console-cmd.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__unreal-engine__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse/check-editor-build-fresh.sh"
          }
        ]
      }
    ]
  }
}
