{
  "tools": [
    {
      "name": "gh",
      "$comment": "gh fits the 'download our own copy' rubric (single ~40MB binary, no OS integration, credentials cache fine to be per-bootstrap). See plugins/bootstrap/skills/bootstrap/references/dependency-philosophy.md.",
      "installPath": "~/AppData/Local/Microsoft/WinGet/Links",
      "download": {
        "windows-amd64": {
          "url": "https://github.com/cli/cli/releases/download/v2.92.0/gh_2.92.0_windows_amd64.zip",
          "sha256": "b6a8df3c8c6b9c80f290906387673bc4d272840f3789c5650e0e4e6e75522785",
          "archive_path": "bin/gh.exe"
        },
        "macos-amd64": {
          "url": "https://github.com/cli/cli/releases/download/v2.92.0/gh_2.92.0_macOS_amd64.zip",
          "sha256": "ae9bb327ab0d91071bdada79f8f14034a2a0f19b0e001835a782eafa519d2af0",
          "archive_path": "gh_2.92.0_macOS_amd64/bin/gh"
        },
        "macos-arm64": {
          "url": "https://github.com/cli/cli/releases/download/v2.92.0/gh_2.92.0_macOS_arm64.zip",
          "sha256": "b11c54f6bd7d15ed6590475079e5b2fcf36f45d3991a80041b29c9d0cc1f1d07",
          "archive_path": "gh_2.92.0_macOS_arm64/bin/gh"
        },
        "ubuntu-amd64": {
          "url": "https://github.com/cli/cli/releases/download/v2.92.0/gh_2.92.0_linux_amd64.tar.gz",
          "sha256": "b57848131bdf0c229cd35e1f2a51aa718199858b2e728410b37e89a428943ec4",
          "archive_path": "gh_2.92.0_linux_amd64/bin/gh"
        }
      },
      "install": {
        "windows": "winget install --id GitHub.cli --accept-source-agreements --accept-package-agreements --silent --disable-interactivity",
        "macos": "brew install gh",
        "ubuntu": "manual"
      }
    },
    {
      "name": "git",
      "install": {
        "windows": "winget install --id Git.Git --accept-source-agreements --accept-package-agreements --silent --disable-interactivity",
        "macos": "manual",
        "ubuntu": "manual"
      }
    },
    {
      "name": "uv",
      "install": {
        "macos": "curl -LsSf https://astral.sh/uv/install.sh | sh",
        "windows": "powershell -ExecutionPolicy ByPass -c \"irm https://astral.sh/uv/install.ps1 | iex\"",
        "ubuntu": "curl -LsSf https://astral.sh/uv/install.sh | sh"
      }
    }
  ],
  "venv": {
    "check_imports": []
  },
  "shared_lib_imports": ["bootstrap_lib"],
  "script": {
    "path": "scripts/bootstrap.py",
    "entry_point": "bootstrap"
  }
}
